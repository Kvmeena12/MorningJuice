# ============================================
# JuiceMorning Backend Environment Variables
# Copy this file to .env and fill in values
# ============================================

# MongoDB URI (local or Atlas)
# Local:   mongodb://localhost:27017/juicemorning
# Atlas:   mongodb+srv://USER:PASS@cluster.mongodb.net/juicemorning
DATABASE_URI=mongodb://localhost:27017/juicemorning

# JWT Secret - change this in production!
JWT_SECRET=juicemorning_super_secret_key_2026

# Razorpay Keys (https://dashboard.razorpay.com/app/keys)
RAZORPAY_KEY_ID=rzp_live_SkmYQ8Fb1RjlYQ
RAZORPAY_KEY_SECRET=NyvhzYLi669azgZIPheW8lA4XX

# Server Port
PORT=5000

# Frontend URLs (for CORS whitelist)
FRONTEND_URL=http://localhost:3000
